# WireTapper API Keys — kopieer naar .env en vul in
# Wigle.net — https://wigle.net/account (API name + token)
WIGLE_API_NAME=
WIGLE_API_TOKEN=

# OpenCellID — https://opencellid.org/auth/login
OPENCELLID_API_KEY=

# Shodan — https://account.shodan.io/ (Premium vereist)
SHODAN_API_KEY=

# wpa-sec — https://wpa-sec.stanev.org/?submit
WPASEC_KEY=
